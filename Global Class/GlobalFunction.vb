    Public Function ClosingQuantity_New(ByVal ITEMCODE As String, ByVal STORECODE As String, ByVal UOM As String) As Double

        Dim ClsQty As Double
        Try

            gconnection.openConnection()
            gcommand = New SqlCommand("SPA_ClosingQtyItem_INV", gconnection.Myconn)
            gcommand.CommandTimeout = 1000000000
            gcommand.CommandType = CommandType.StoredProcedure
            gcommand.Parameters.Add(New SqlParameter("@ItemCode", SqlDbType.VarChar, 20, ParameterDirection.Input)).Value = ITEMCODE
            gcommand.Parameters.Add(New SqlParameter("@Uom", SqlDbType.VarChar, 20, ParameterDirection.Input)).Value = UOM
            gcommand.Parameters.Add(New SqlParameter("@StoreCode", SqlDbType.VarChar, 20, ParameterDirection.Input)).Value = STORECODE
            gcommand.Parameters.Add(New SqlParameter("@closingQty", SqlDbType.Float, 53))
            gcommand.Parameters("@closingQty").Direction = ParameterDirection.Output
            gcommand.ExecuteNonQuery()
            ClsQty = Val(gcommand.Parameters("@closingQty").Value.ToString())

        Catch ex As Exception
            ClsQty = 0
            MsgBox("Error in closing cal: " & ex.Message)
        Finally
            gconnection.closeConnection()
        End Try

        Return ClsQty

    End Function
