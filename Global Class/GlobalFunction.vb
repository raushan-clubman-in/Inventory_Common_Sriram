                            TaxRebate = gdataset.Tables("TAXREBATE").Rows(0).Item("TAXREBATE")
                        End If

                        'FOR OPSTOCK QTY
                        sqlstring = "SELECT ISNULL(SUM(ISNULL(OPSTOCK,0)),0) as OPSTOCK FROM INVENTORYITEMMASTER WHERE ITEMCODE='" & dr("Itemcode") & "' AND ISNULL(FREEZE,'') <> 'Y' AND ISNULL(STORECODE,'')='" & dr("STORECODE") & "'"
