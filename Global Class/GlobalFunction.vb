    Public Function UpdateTransportationCharges(ByVal DocNo As String)

        Dim sqlstring As String

        sqlstring = "UPDATE GRN_DETAILS SET TRANS_AMOUNT=NULL where grndetails='" & DocNo & "' "
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        sqlstring = "UPDATE GRN_DETAILS SET TRANS_AMOUNT = (T.AMOUNT)  FROM (SELECT AMOUNT,Grndetails FROM GRN_DETAILS WHERE ITEMCODE IN (select ISNULL(trans_itemcode,'') from INV_LINKSETUP) AND ISNULL(Voiditem,'')<>'Y' AND ITEM_TYPE='NO') T  WHERE T.GRNDETAILS=GRN_DETAILS.GRNDETAILS  AND ITEMCODE NOT IN (select ISNULL(trans_itemcode,'') from INV_LINKSETUP)  and GRN_DETAILS.GRNDETAILS='" & DocNo & "' "
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        sqlstring = "UPDATE GRN_DETAILS SET TRANS_AMOUNT = (T.baseamount)  FROM (SELECT baseamount,Grndetails FROM GRN_DETAILS WHERE ITEMCODE IN (select ISNULL(trans_itemcode,'') from INV_LINKSETUP) AND ISNULL(Voiditem,'')<>'Y' AND ITEM_TYPE='YES') T  WHERE T.GRNDETAILS=GRN_DETAILS.GRNDETAILS  AND ITEMCODE NOT IN (select ISNULL(trans_itemcode,'') from INV_LINKSETUP) and GRN_DETAILS.GRNDETAILS='" & DocNo & "' "
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        sqlstring = "UPDATE GRN_DETAILS SET TRANS_AMOUNT = (TRANS_AMOUNT * QTY) WHERE ISNULL(TRANS_AMOUNT,0)<>0  and Grndetails='" & DocNo & "' "
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        sqlstring = "UPDATE GRN_DETAILS SET TRANS_AMOUNT = TRANS_AMOUNT/((SELECT TOTALQTY FROM GRN_HEADER G WHERE GRN_DETAILS.Grndetails=G.Grndetails )-(SELECT QTY FROM GRN_DETAILS G1 WHERE ITEMCODE IN (select ISNULL(trans_itemcode,'') from INV_LINKSETUP) AND  GRN_DETAILS.Grndetails=G1.Grndetails  ))  WHERE Grndetails='" & DocNo & "'  AND ISNULL(TRANS_AMOUNT,0)<>0 "
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)

    End Function


    Public Sub check_MinMaxQTY(ByVal MinMax As String, ByVal storecode As String, ByVal Itemcode As String, ByVal qty As Double)
        Dim sqlstring, sqlstring2 As String
        Dim Min, Max, clstk As Double

        sqlstring2 = "select top 1 isnull(closingstock,0) as closingstock from closingqty where itemcode='" & Itemcode & "' and storecode='" & storecode & "' order by Autoid desc"
        gconnection.getDataSet(sqlstring2, "stk")
        If gdataset.Tables("stk").Rows.Count > 0 Then
            clstk = Val(gdataset.Tables("stk").Rows(0).Item("closingstock"))
        Else
            clstk = 0
        End If

        sqlstring = "select isnull(minqty,0) as minqty,isnull(maxqty,0 ) as maxqty from inv_InventoryOpenningstock where itemcode='" & Itemcode & "' and storecode='" & storecode & "' "
        gconnection.getDataSet(sqlstring, "spl")
        If gdataset.Tables("spl").Rows.Count > 0 Then
            Min = gdataset.Tables("spl").Rows(0).Item("minqty")
            Max = gdataset.Tables("spl").Rows(0).Item("maxqty")
            If MinMax = "N" Then
                If Min > 0 Then
                    If Min >= qty + clstk Then
                        MessageBox.Show("" + Itemcode.ToUpper() + "  TOUCHING MINMUM QTY. IN STORE " + storecode.ToUpper(), MyCompanyName, MessageBoxButtons.OK, MessageBoxIcon.Exclamation, MessageBoxDefaultButton.Button1)
                    End If
                End If
            Else
                If Max > 0 Then
                    If Max <= qty + clstk Then
                        MessageBox.Show("" + Itemcode.ToUpper() + "  TOUCHING MAXIMUM QTY. IN STORE " + storecode.ToUpper(), MyCompanyName, MessageBoxButtons.OK, MessageBoxIcon.Exclamation, MessageBoxDefaultButton.Button1)
                    End If
                End If
            End If
        End If

    End Sub

