    Public Function Adjustment_Triggers(ByVal DOCDETAILS As String)
        Dim dr, dr1 As DataRow
        Dim TaxRebate, sqlstring As String
        Dim Opstock, Opvalue, CLSTK, CLSVALUE As Double
        Dim GRNFLAG As Integer
        GRNFLAG = 0

        sqlstring = "Select storelocationcode as storecode,Itemcode,docDATE from STOCKadjustDETAILS WHERE docdetails='" & Trim(DOCDETAILS) & "' group by storelocationcode,Itemcode,docDATE"
        gconnection.getDataSet(sqlstring, "GRN")
        If gdataset.Tables("GRN").Rows.Count > 0 Then
            For Each dr In gdataset.Tables("GRN").Rows
                sqlstring = "SELECT DOCDATE FROM STOCKISSUEDETAIL WHERE ITEMCODE='" & dr("ITEMCODE") & "' AND ISNULL(VOID,'N')<> 'Y' AND DOCDATE >='" & Format(dr("DOCDATE"), "dd/MMM/yyyy") & "' GROUP BY DOCDATE ORDER BY DOCDATE"
