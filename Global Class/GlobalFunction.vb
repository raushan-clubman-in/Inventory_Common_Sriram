                If gdataset.Tables("ISS").Rows.Count > 0 Then
                    For Each dr1 In gdataset.Tables("ISS").Rows

                        'FOR INTIALIZE
                        sqlstring = "UPDATE STOCKISSUEDETAIL SET RATE=0,AMOUNT=0 WHERE ITEMCODE='" & dr("ITEMCODE") & "' AND DOCDATE='" & Format(dr1("DOCDATE"), "dd/MMM/yyyy") & "'"
                        gconnection.getDataSet(sqlstring, "ISS1")

                        'FOR TAX REBATE APPLICABLE
