                        sqlstring = "SELECT ISNULL(SUM(ISNULL(QTY,0)),0)  AS OPSTOCK FROM GRN_DETAILS WHERE ITEMCODE='" & dr("Itemcode") & "' AND ISNULL(VOIDITEM,'') <> 'Y' AND GRNDATE <= '" & Format(dr1("DOCDATE"), "dd/MMM/yyyy") & "' AND ISNULL(STORECODE,'')='" & dr("STORECODE") & "'"
