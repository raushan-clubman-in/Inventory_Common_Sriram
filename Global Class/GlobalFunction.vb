    Public Function BatchnoPosting()
        Dim sqlstring As String



        sqlstring = "UPDATE closingqty SET batchno = g.batchno from INV_INVENTORYOPENNINGSTOCK g where closingqty.itemcode=g.itemcode And CLOSINGQTY.STORECODE=G.STORECODE And ttype='OPENNING'"
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        '    If type = "GRN" Then trnno='" & Docdetails & "' and 
        sqlstring = "UPDATE closingqty SET batchno = g.batch_no from grn_details g where closingqty.itemcode=g.itemcode and Trnno=g.grndetails"
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        '   ElseIf type = "ISSUE" Then  trnno='" & Docdetails & "' and
        sqlstring = "UPDATE closingqty SET closingqty.batchno = STOCKISSUEDETAIL.batchno from STOCKISSUEDETAIL where closingqty.itemcode=STOCKISSUEDETAIL.itemcode and Trnno=STOCKISSUEDETAIL.Docdetails"
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        '   ElseIf type = "STOCK TRANSFER" Then  trnno='" & Docdetails & "' and
        sqlstring = "UPDATE closingqty SET closingqty.batchno = STOCKTRANSFERDETAIL.batchno from STOCKTRANSFERDETAIL where closingqty.itemcode=STOCKTRANSFERDETAIL.itemcode and Trnno=STOCKTRANSFERDETAIL.Docdetails"
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        '   ElseIf type = "ADJUSTMENT" Then  trnno='" & Docdetails & "' and
        sqlstring = "UPDATE closingqty SET closingqty.batchno = STOCKADJUSTDETAILS.batchno from STOCKADJUSTDETAILS where closingqty.itemcode=STOCKADJUSTDETAILS.itemcode and Trnno=STOCKADJUSTDETAILS.Docdetails"
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        '   ElseIf type = "DAMAGE" Then  trnno='" & Docdetails & "' and
        sqlstring = "UPDATE closingqty SET closingqty.batchno = STOCKDMGDETAIL.batchno from STOCKDMGDETAIL where closingqty.itemcode=STOCKDMGDETAIL.itemcode and Trnno=STOCKDMGDETAIL.Docdetails"
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        '   ElseIf type = "CONSUMPTION" Then  trnno='" & Docdetails & "' and
        sqlstring = "UPDATE closingqty SET closingqty.batchno = stockConsumption_1.batchno from stockConsumption_1 where closingqty.itemcode=stockConsumption_1.itemcode and Trnno=stockConsumption_1.DOCNO"
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        '  type = "GRN" Closing qty  Batch Rate updation
        sqlstring = "UPDATE CLOSINGQTY  SET BATCHRATE=G.RATE FROM GRN_DETAILS G WHERE G.ITEMCODE=CLOSINGQTY.ITEMCODE AND G.BATCH_NO=CLOSINGQTY.BATCHNO AND ISNULL(CLOSINGQTY.BATCHNO,'')<>''"
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        ' type = "ISSUE" Rate and Amount update from Closing qty Batch Rate
        sqlstring = "update STOCKISSUEDETAIL set rate=c.batchrate,amount=c.batchrate*STOCKISSUEDETAIL.qty from closingqty c where STOCKISSUEDETAIL.itemcode=c.itemcode and STOCKISSUEDETAIL.batchno=c.batchno and c.Trnno=STOCKISSUEDETAIL.Docdetails"
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        ' type = "STOCK TRANSFER" Rate and Amount update from Closing qty Batch Rate
        sqlstring = " update STOCKTRANSFERDETAIL Set rate=c.batchrate, amount = c.batchrate * STOCKTRANSFERDETAIL.qty from closingqty c where STOCKTRANSFERDETAIL.itemcode=c.itemcode And STOCKTRANSFERDETAIL.batchno=c.batchno And c.Trnno=STOCKTRANSFERDETAIL.Docdetails"
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        ' type = "ADJUSTMENT" Rate and Amount update from Closing qty Batch Rate
        sqlstring = "update STOCKADJUSTDETAILS set rate=c.batchrate,amount=c.batchrate*STOCKADJUSTDETAILS.Adjustedstock from closingqty c where STOCKADJUSTDETAILS.itemcode=c.itemcode and STOCKADJUSTDETAILS.batchno=c.batchno and c.Trnno=STOCKADJUSTDETAILS.Docdetails"
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        ' type = "DAMAGE" Rate and Amount update from Closing qty Batch Rate
        sqlstring = "update STOCKDMGDETAIL set rate=c.batchrate,amount=c.batchrate*STOCKDMGDETAIL.dmgqty from closingqty c where STOCKDMGDETAIL.itemcode=c.itemcode and STOCKDMGDETAIL.batchno=c.batchno and c.Trnno=STOCKDMGDETAIL.Docdetails"
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        ' type = "CONSUMPTION" Rate and Amount update from Closing qty Batch Rate
        sqlstring = "update stockConsumption_1 set rate=c.batchrate,amount=c.batchrate*stockConsumption_1.consumption from closingqty c where stockConsumption_1.itemcode=c.itemcode and stockConsumption_1.batchno=c.batchno and c.Trnno=stockConsumption_1.Docno"
        gconnection4BGP.ExcuteStoreProcedure(sqlstring)
        '  End If
    End Function





    Public Function NewAccountPosting(ByVal Docdetails As String, ByVal type As String)
        Dim SQLS, sqlstring, itemc As String
        Try



            sqlstring = " DELETE FROM INV_JV"
            gconnection4BGP.ExcuteStoreProcedure(sqlstring)


            sqlstring = " DELETE FROM INV_JV2"
            gconnection4BGP.ExcuteStoreProcedure(sqlstring)

            sqlstring = " DELETE FROM INV_JV3"
            gconnection4BGP.ExcuteStoreProcedure(sqlstring)

            sqlstring = " DELETE FROM INV_JV4"
            gconnection4BGP.ExcuteStoreProcedure(sqlstring)

            If type = "GRN" Then

                sqlstring = "alter table GRN_HEADER disable trigger all"
                gconnection.ExcuteStoreProcedure(sqlstring)
                sqlstring = "alter table Grn_details disable trigger all"
                gconnection.ExcuteStoreProcedure(sqlstring)

                sqlstring = "UPDATE Grn_details SET ITEM_TYPE  = 'YES' WHERE ITEM_TYPE IS NULL AND Itemcode IN (SELECT ITEMCODE FROM Vw_Inv_TaxRebateItem)"
                gconnection4BGP.ExcuteStoreProcedure(sqlstring)

                sqlstring = "UPDATE Grn_details SET ITEM_TYPE  = 'NO' WHERE ISNULL(ITEM_TYPE,'')='' AND Itemcode NOT  IN (SELECT ITEMCODE FROM Vw_Inv_TaxRebateItem)"
                gconnection4BGP.ExcuteStoreProcedure(sqlstring)

                sqlstring = "UPDATE GRN_HEADER SET TOTALQTY =( SELECT SUM(QTY) FROM Grn_details WHERE ISNULL(VOIDITEM,'N')<>'Y' AND GRN_HEADER.Grndetails=Grn_details.Grndetails) "
                gconnection4BGP.ExcuteStoreProcedure(sqlstring)



                sqlstring = "UPDATE GRN_DETAILS SET TRANS_AMOUNT=NULL where grndetails='" & Docdetails & "' "
                gconnection4BGP.ExcuteStoreProcedure(sqlstring)
                sqlstring = "UPDATE GRN_DETAILS SET TRANS_AMOUNT = (T.AMOUNT)  FROM (SELECT AMOUNT,Grndetails FROM GRN_DETAILS WHERE ITEMCODE IN (select ISNULL(trans_itemcode,'') from INV_LINKSETUP) AND ISNULL(Voiditem,'')<>'Y' AND ITEM_TYPE='NO') T  WHERE T.GRNDETAILS=GRN_DETAILS.GRNDETAILS  AND ITEMCODE NOT IN (select ISNULL(trans_itemcode,'') from INV_LINKSETUP)  and GRN_DETAILS.GRNDETAILS='" & Docdetails & "' "
                gconnection4BGP.ExcuteStoreProcedure(sqlstring)
                sqlstring = "UPDATE GRN_DETAILS SET TRANS_AMOUNT = (T.baseamount)  FROM (SELECT baseamount,Grndetails FROM GRN_DETAILS WHERE ITEMCODE IN (select ISNULL(trans_itemcode,'') from INV_LINKSETUP) AND ISNULL(Voiditem,'')<>'Y' AND ITEM_TYPE='YES') T  WHERE T.GRNDETAILS=GRN_DETAILS.GRNDETAILS  AND ITEMCODE NOT IN (select ISNULL(trans_itemcode,'') from INV_LINKSETUP) and GRN_DETAILS.GRNDETAILS='" & Docdetails & "' "
                gconnection4BGP.ExcuteStoreProcedure(sqlstring)
                sqlstring = "UPDATE GRN_DETAILS SET TRANS_AMOUNT = (TRANS_AMOUNT * QTY) WHERE ISNULL(TRANS_AMOUNT,0)<>0  and Grndetails='" & Docdetails & "' "
                gconnection4BGP.ExcuteStoreProcedure(sqlstring)
                sqlstring = "UPDATE GRN_DETAILS SET TRANS_AMOUNT = TRANS_AMOUNT/((SELECT TOTALQTY FROM GRN_HEADER G WHERE GRN_DETAILS.Grndetails=G.Grndetails )-(SELECT QTY FROM GRN_DETAILS G1 WHERE ITEMCODE IN (select ISNULL(trans_itemcode,'') from INV_LINKSETUP) AND  GRN_DETAILS.Grndetails=G1.Grndetails  ))  WHERE Grndetails='" & Docdetails & "'  AND ISNULL(TRANS_AMOUNT,0)<>0 "
                gconnection4BGP.ExcuteStoreProcedure(sqlstring)




                sqlstring = "UPDATE Grn_details SET supplierinvno  = g.supplierinvno from grn_header g where grn_details.grndetails=g.grndetails AND Grn_details.Grndetails='" & Docdetails & "' "
                gconnection4BGP.ExcuteStoreProcedure(sqlstring)

                sqlstring = "UPDATE Grn_details SET VENDOR_TYPE=VENDORTYPE FROM SUPPLIERDETAILS S, Grn_details G WHERE S.vendorcode=G.Suppliercode AND G.grndetails='" & Docdetails & "' "
                gconnection4BGP.ExcuteStoreProcedure(sqlstring)

                sqlstring = "UPDATE Grn_details SET TAX_TYPE=TAXTYPE,ITEM_TYPE=TaxRebate FROM INV_InventoryItemMaster S, Grn_details G WHERE S.itemcode=G.Itemcode AND G.grndetails='" & Docdetails & "' "
                gconnection4BGP.ExcuteStoreProcedure(sqlstring)


                sqlstring = "alter table GRN_HEADER ENABLE trigger all"
                gconnection.ExcuteStoreProcedure(sqlstring)
                sqlstring = "alter table Grn_details ENABLE trigger all"
                gconnection.ExcuteStoreProcedure(sqlstring)


                '' wHICH TAX REBATE IS YES AND TAXCODE IS NONE
                If gShortname = "RSAOI" Then
                    sqlstring = "INSERT INTO INV_JV (DOCTYPE,TYPE,DOCNO,DOCDATE,ITEMCODE,STORECODE,CATEGORY,AMOUNT) SELECT 'GRN' ,'ITEM',grndetails,grndate,Itemcode,storecode,category ,amountafterdiscount+TAXAMOUNT  FROM Grn_details  where isnull( Voiditem,'N')<>'Y' AND isnull(ITEM_TYPE,'NO')='YES' AND  GRNDETAILS='" + Docdetails + "'"
                    gconnection4BGP.ExcuteStoreProcedure(sqlstring)
                Else
                    sqlstring = " INSERT INTO INV_JV (DOCTYPE,TYPE,DOCNO,DOCDATE,ITEMCODE,STORECODE,CATEGORY,AMOUNT) SELECT 'GRN' ,'ITEM',grndetails,grndate,Itemcode,storecode,category ,amountafterdiscount FROM Grn_details  where isnull( Voiditem,'N')<>'Y' AND ISNULL(taxcode,'')='NONE' AND isnull(ITEM_TYPE,'NO')='YES' AND  GRNDETAILS='" + Docdetails + "'"
                    gconnection4BGP.ExcuteStoreProcedure(sqlstring)
                End If



                '' wHICH TAX REBATE IS NO AND TAXCODE IS NONE
                If gShortname = "RSAOI" Then
                    sqlstring = " INSERT INTO INV_JV (DOCTYPE,TYPE,DOCNO,DOCDATE,ITEMCODE,STORECODE,CATEGORY,AMOUNT) SELECT 'GRN' ,'ITEM',grndetails,grndate,Itemcode,storecode,category ,AMOUNT FROM Grn_details  where isnull( Voiditem,'N')<>'Y' AND isnull(ITEM_TYPE,'NO')='NO' AND  GRNDETAILS='" + Docdetails + "'"
