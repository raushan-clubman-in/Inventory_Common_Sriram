    Public Function GetPass(ByVal vUser As String) As String
        Dim Vdesc As String
        Dim vAsc As Long
        Dim vPass As String
        Dim Loopindex As Long
        Vdesc = ""
        For Loopindex = 1 To Len(vUser)
            Vdesc = Mid(vUser, Loopindex, 1)
            vAsc = Asc(Vdesc) + 150
            vPass = Trim(vPass) & Chr(vAsc)
        Next Loopindex
        GetPass = vPass
    End Function
