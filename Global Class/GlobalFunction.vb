                sqlstring = "UPDATE INVENTORYITEMMASTER SET PURCHASERATE=isnull(CLVALUE,0)/ISNULL(CLSTOCK,0) WHERE ITEMCODE ='" & dr("ITEMCODE") & "' AND STORECODE ='" & dr("STORECODE") & "'  AND ISNULL(CLSTOCK,0)<>0"
                gconnection.getDataSet(sqlstring, "CLSTK")

                'FOR STD_COSTINGDEL
                sqlstring = "UPDATE STD_COSTINGDEL SET RATE=(SELECT TOP 1 CASE WHEN ISNULL(CLSTOCK,0)>0 THEN isnull(CLVALUE,0)/ISNULL(CLSTOCK,0) ELSE ISNULL(PURCHASERATE,0) END FROM INVENTORYITEMMASTER B WHERE B.ITEMCODE=STD_COSTINGDEL.ITEMCODE) WHERE ITEMCODE='" & dr("ITEMCODE") & "'"
                gconnection.getDataSet(sqlstring, "CLSTK")

                'FOR STD_COSTINGDEL
                sqlstring = "UPDATE STD_COSTINGDEL SET AMOUNT=QTY*RATE WHERE ITEMCODE='" & dr("ITEMCODE") & "'"
                gconnection.getDataSet(sqlstring, "CLSTK")

            Next dr
        End If
    End Function



