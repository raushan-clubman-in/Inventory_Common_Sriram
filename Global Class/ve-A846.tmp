            str1 = str1 & " FROM dbo.stockissuedetail INNER JOIN dbo.stockissueheader "
            str1 = str1 & " ON dbo.stockissuedetail.docdetails = dbo.stockissueheader.docdetails"
            gconnection.dataOperation1(6, str1, "item")

            'On 22OCT12 Transaction Date for Catholic club by VENUJD
            str1 = "   ALTER  VIEW [dbo].[VW_INV_STKTRFBILL]"
            str1 = str1 & " AS "
            str1 = str1 & " SELECT ISNULL(H.DOCDETAILS,'') AS DOCDETAILS,H.DOCDATE,ISNULL(H.FROMSTORECODE,'') AS FROMSTORECODE,"
            str1 = str1 & " ISNULL(H.FROMSTOREDESC,'') AS FROMSTOREDESC,ISNULL(H.TOSTORECODE,'') AS TOSTORECODE,"
            str1 = str1 & " ISNULL(H.TOSTOREDESC,'') AS TOSTOREDESC,ISNULL(H.CHALLENNO,'') AS CHALLENNO,H.CHALLENDATE AS CHALLENDATE,"
