            str1 = str1 & " ISNULL(HDR.PRODUCT_TYPE,'') PRODUCT_TYPE, ISNULL(HDR.REMARKS,'') REMARKS,ISNULL(HDR.updsign,'') updsign,"
            str1 = str1 & " ISNULL(HDR.updfooter,'') updfooter,"
