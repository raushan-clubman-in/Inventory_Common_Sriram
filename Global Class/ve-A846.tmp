            str1 = "   ALTER  VIEW  [dbo].[VW_INV_ISSUEBILL]"
            str1 = str1 & " AS"
            str1 = str1 & " SELECT TOP 100 PERCENT dbo.stockissueheader.docdetails, dbo.stockissueheader.docdate,"
            str1 = str1 & " dbo.stockissueheader.storelocationname, dbo.stockissueheader.opstorelocationname, dbo.stockissuedetail.itemcode,"
            str1 = str1 & " dbo.stockissueheader.storelocationcode,dbo.stockissueheader.opstorelocationcode, dbo.stockissuedetail.itemname,"
            str1 = str1 & " dbo.stockissuedetail.uom,dbo.stockissuedetail.qty, dbo.stockissuedetail.rate, dbo.stockissuedetail.amount ,isnull(dbo.stockissuedetail.clsqty,0) as clsqty ,"
            str1 = str1 & " dbo.stockissueheader.indentno ,  dbo.stockissueheader.indentdate,dbo.stockissueheader.remarks,"
            str1 = str1 & " dbo.stockissueheader.UPDFOOTER,dbo.stockissueheader.UPDSIGN,"
