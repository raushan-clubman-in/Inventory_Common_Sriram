    End Sub

    Sub bindcodefield()
        Dim sql1 As String = "Select Code,description,accountcode,accountdesc,slcode,sldesc,costcentercode,costcenterdesc from Accountstagging where tablename='" & tabname & "' UNION "
        sql1 = sql1 & " SELECT distinct " & CodeField & "," & Codedesc & ",'' AS accountcode,'' AS accountdesc,'' AS slcode,'' AS sldesc,'' AS costcentercode,'' AS costcenterdesc FROM " & tabname & " "
        sql1 = sql1 & " WHERE " & CodeField & " NOT IN (Select Code from Accountstagging where tablename='" & tabname & "') "
        'order by " & Codeorderfield

        gconnection.getDataSet(sql1, "Accountstagging")
        If gdataset.Tables("Accountstagging").Rows.Count > 0 Then
            For i As Integer = 0 To gdataset.Tables("Accountstagging").Rows.Count - 1
                With AxfpSpread1
                    .Row = i + 1
                    .Col = 1
                    .Text = gdataset.Tables("Accountstagging").Rows(i).Item("Code")

                    .Row = i + 1
                    .Col = 2
                    .Text = gdataset.Tables("Accountstagging").Rows(i).Item("description")
                    .Row = i + 1
                    .Col = 3
                    .Text = gdataset.Tables("Accountstagging").Rows(i).Item("accountcode")
                    .Row = i + 1
                    .Col = 4
                    .Text = gdataset.Tables("Accountstagging").Rows(i).Item("accountdesc")
                    .Row = i + 1
                    .Col = 5
                    .Text = gdataset.Tables("Accountstagging").Rows(i).Item("slcode")
                    .Row = i + 1
                    .Col = 6
                    .Text = gdataset.Tables("Accountstagging").Rows(i).Item("sldesc")
                    .Row = i + 1
                    .Col = 7
                    .Text = gdataset.Tables("Accountstagging").Rows(i).Item("costcentercode")
                    .Row = i + 1
                    .Col = 8
                    .Text = gdataset.Tables("Accountstagging").Rows(i).Item("costcenterdesc")


                End With
            Next
        End If

        AxfpSpread1.Row = 1
        AxfpSpread1.Col = 3
        AxfpSpread1.Focus()
    End Sub

